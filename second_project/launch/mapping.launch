<launch>

  <!-- Set use_sim_time if bag is recorded with /clock -->
  <param name="use_sim_time" value="true" />

  <!-- Launch the scan merging node -->
  <node name="laser_merge" pkg="second_project" type="laser_merge" output="screen" />

  <node name="odometry_tf" pkg="second_project" type="odometry_tf" output="screen" />

  <!-- Play the bag file from ~/catkin_ws/data -->
  <node pkg="rosbag" type="play" name="bag_play" args="--clock $(env HOME)/data/robotics2.bag" />

  <node pkg="tf2_ros" type="static_transform_publisher" name="sick_back_tf"
      args="-0.3 0.0 -0.115 3.1415 0 3.1415 base_link sick_back" />

  <!-- Optional: Launch RViz with config -->
  <node pkg="rviz" type="rviz" name="rviz" args="-d $(find second_project)/rviz/merge_view.rviz" required="true" />
  
</launch>