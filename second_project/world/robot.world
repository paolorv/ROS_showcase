include "robot.inc"

define floorplan model
(
  color "gray30"
  boundary 1
  gui_nose 0
  gui_grid 0
  gui_outline 0
  gripper_return 0
  fiducial_return 0
  laser_return 1
)

resolution 0.02
interval_sim 100

window
(
  size [ 800 600 ]
  center [ 0 0 ]
  rotate [ 0 0 ]
  scale 20
)

floorplan
(
  name "map"
  size [ 20.0 20.0 0.8]
  pose [ 0 0 0 0 ]
  bitmap "$(find second_project)/maps/map.pgm"
)

robot
(
  name "robot"
  pose [ 0 0 0 0 ]
  color "red"
)